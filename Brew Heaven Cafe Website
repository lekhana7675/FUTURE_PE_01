<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Brew Haven Café</title>
<style>
body {
  margin: 0;
  font-family: Arial, sans-serif;
  background-color: #fafafa;
}
header {
  background: #3e2723;
  color: white;
  padding: 20px;
  text-align: center;
}
nav {
  background: #5d4037;
  padding: 10px;
  text-align: center;
}
nav a {
  color: white;
  margin: 0 15px;
  text-decoration: none;
  font-weight: bold;
}
.hero {
  padding: 60px 20px;
  text-align: center;
  background: #d7ccc8;
}
.hero h1 {
  font-size: 2.5em;
}
.section {
  padding: 40px 20px;
  text-align: center;
}
.services {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 20px;
}
.card {
  background: white;
  padding: 20px;
  border-radius: 10px;
  box-shadow: 0 4px 8px rgba(0,0,0,0.1);
}
.cta {
  background: #6d4c41;
  color: white;
  padding: 40px 20px;
}
footer {
  background: #3e2723;
  color: white;
  text-align: center;
  padding: 15px;
}
button {
  padding: 10px 20px;
  border: none;
  background: #3e2723;
  color: white;
  cursor: pointer;
  border-radius: 5px;
}
button:hover {
  background: #5d4037;
}
</style>
</head>
<body>

<header>
  <h1>Brew Haven Café</h1>
  <p>Your favorite coffee spot to relax, work & connect</p>
</header>

<nav>
  <a href="#home">Home</a>
  <a href="#services">Menu</a>
  <a href="#contact">Contact</a>
</nav>

<section class="hero" id="home">
  <h1>Relax. Sip. Enjoy.</h1>
  <p>A cozy café in Bhimavaram where great coffee meets good vibes.</p>
  <button onclick="alert('Visit us today!')">Visit Now</button>
</section>

<section class="section" id="services">
  <h2>Our Specials</h2>
  <div class="services">
    <div class="card">
      <h3>☕ Signature Coffee</h3>
      <p>Freshly brewed premium coffee to energize your day.</p>
    </div>
    <div class="card">
      <h3>🍰 Desserts</h3>
      <p>Delicious cakes and pastries to satisfy your cravings.</p>
    </div>
    <div class="card">
      <h3>💻 Work Space</h3>
      <p>Comfortable seating with free WiFi for productivity.</p>
    </div>
    <div class="card">
      <h3>📸 Chill Zone</h3>
      <p>Perfect ambiance for hangouts and Instagram moments.</p>
    </div>
  </div>
</section>

<section class="cta">
  <h2>Visit Brew Haven Today!</h2>
  <p>Located in the heart of Bhimavaram. Walk in anytime!</p>
  <button onclick="alert('Table Reserved!')">Reserve Table</button>
</section>

<section class="section" id="contact">
  <h2>Contact Us</h2>
  <p>📍 Bhimavaram</p>
  <p>📞 +91 9876543210</p>
</section>

<footer>
  <p>© 2026 Brew Haven Café | All Rights Reserved</p>
</footer>

</body>
</html>
